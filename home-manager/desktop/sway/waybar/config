{
	"layer": "top",
	"position": "bottom",

	"modules-left": [
		"sway/workspaces",
		"sway/mode"
	],

	"modules-right": [
		"pulseaudio",
		"network",
		"memory",
		"cpu",
		// "temperature",
		"battery",
		"sway/language",
		"clock",
		"tray"
	],

	// Modules

	"battery": {
		"interval": 10,
		"states": {
			"warning": 30,
			"critical": 15
		},
		"format-time": "{H}:{M:02}",
		"format": "о‚і {icon} {capacity}% ({time})",
		"format-charging": "о‚і пѓ§ {capacity}% ({time})",
		"format-charging-full": "о‚і пѓ§ {capacity}%",
		"format-full": "о‚і {icon} {capacity}%",
		"format-alt": "о‚і {icon} {power}W",
		"format-icons": [
			"п‰„",
			"п‰ѓ",
			"п‰‚",
			"п‰Ѓ",
			"п‰Ђ"
		],
		"tooltip": false
	},
	"clock": {
		"interval": 20,
		"format": "о‚і {:%m/%d %H:%M}",
		"tooltip": false
		//"tooltip-format": "{:%e %B %Y}"
	},

	"cpu": {
		"interval": 5,
		"tooltip": false,
		"format": "о‚і п‹› {usage}%",
		"format-alt": "о‚і п‹› {load}",
		"states": {
			"warning": 70,
			"critical": 90
		}
	},

	"sway/language": {
		"format": "о‚і п„њ {}",
		"min-length": 5,
		"on-click": "swaymsg 'input * xkb_switch_layout next'",
		"tooltip": false
	},

	"memory": {
		"interval": 5,
		"format": "о‚і п”ё {used:0.1f}G/{total:0.1f}G",
		"states": {
			"warning": 70,
			"critical": 90
		},
		"tooltip": false
	},

	"network": {
		"interval": 5,
		"format-wifi": "о‚і п‡«  ({signalStrength}%)",
		"format-ethernet": "о‚і пћ– {ifname}",
		"format-disconnected": "о‚і No connection",
		"format-alt": "о‚і у°©џ {ipaddr}/{cidr}",
		"tooltip": false
	},

	"sway/mode": {
		"format": "{}",
		"tooltip": false
	},


	"sway/workspaces": {
		"disable-scroll-wraparound": true,
		"smooth-scrolling-threshold": 4,
		"enable-bar-scroll": true,
		"format": "{name}"
	},

	"pulseaudio": {
		"format": "о‚і {icon} {volume}%",
		"format-bluetooth": "о‚і {icon}пЉ” {volume}%",
		"format-muted": "пЂ¦",
		"format-icons": {
			"headphone": "пЂҐ",
			"hands-free": "п–ђ",
			"headset": "п–ђ",
			"phone": "п‚•",
			"portable": "п‚•",
			"car": "п†№",
			"default": ["пЂ§", "пЂЁ"]
		},
		"scroll-step": 1,
		"on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
		"tooltip": false
	},

	"temperature": {
		"critical-threshold": 90,
		"interval": 5,
		"format": "о‚і {icon} {temperatureC}В°",
		"format-icons": [
			"п‹‹",
			"п‹Љ",
			"п‹‰",
			"п‹€",
			"п‹‡"
		],
